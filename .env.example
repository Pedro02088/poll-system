# ==========================================
# .env.example — modelo de variáveis de ambiente
# Copie os blocos para backend/.env e frontend/.env e preencha.
# NUNCA versione os .env reais.
# ==========================================

# ---------- BACKEND (backend/.env) ----------
APP_NAME="Sistema de Enquetes"
APP_ENV=local
APP_KEY=                      # gere com: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=enquetes
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:5173
FRONTEND_URL=http://localhost:5173

QUEUE_CONNECTION=database

# E-mails (recuperação de senha, notificações de voto) via Mailtrap sandbox
# Rode `php artisan queue:work` para processar as notificações enfileiradas.
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="nao-responda@enlace.com"
MAIL_FROM_NAME="Enlace"

# ---------- FRONTEND (frontend/.env) ----------
VITE_API_URL=http://localhost:8000/api

# ==========================================
# PRODUÇÃO — diferenças em relação ao local
# ==========================================
# Backend (Railway):
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://SEU-BACKEND.up.railway.app
#   FRONTEND_URL=https://SEU-FRONT.vercel.app   # origem liberada no CORS
#
#   # Sessão cross-domain (front e back em domínios diferentes):
#   SESSION_DRIVER=database
#   SESSION_SAME_SITE=none      # obrigatório para o cookie viajar entre domínios
#   SESSION_SECURE_COOKIE=true  # exigido pelo navegador quando SameSite=None
#   SESSION_DOMAIN=             # vazio: cookie fica preso ao domínio da API
#
#   QUEUE_CONNECTION=database   # worker roda como serviço separado (queue:work)
#
# Frontend (Vercel):
#   VITE_API_URL=https://SEU-BACKEND.up.railway.app/api
