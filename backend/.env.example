APP_NAME=Enlace
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------- Banco ----------
# Crie o banco antes de migrar:  CREATE DATABASE enquetes;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=enquetes
DB_USERNAME=root
DB_PASSWORD=

# ---------- Sessão (autenticação) ----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# Origem do front liberada no CORS (aceita várias, separadas por vírgula).
# Também é a base do link de recuperação de senha enviado por e-mail.
FRONTEND_URL=http://localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------- Fila ----------
# As notificações de voto são enfileiradas. Rode num terminal separado:
#   php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database

# ---------- E-mail ----------
# Recuperação de senha e notificações de voto.
# Use uma caixa sandbox do Mailtrap (https://mailtrap.io) e cole as credenciais.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="nao-responda@enlace.com"
MAIL_FROM_NAME="Enlace"

# ==========================================
# PRODUÇÃO (Railway) — o que muda
# ==========================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://SEU-BACKEND.up.railway.app
# FRONTEND_URL=https://SEU-FRONT.vercel.app
# SESSION_SAME_SITE=none      # cookie precisa viajar entre domínios
# SESSION_SECURE_COOKIE=true  # exigido quando SameSite=None
# SESSION_DOMAIN=             # vazio: cookie preso ao domínio da API
